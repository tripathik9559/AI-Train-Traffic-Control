# ─────────────────────────────────────────────────────────────────────────────
#  Railway Control System — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=your-secret-key-here-minimum-50-characters-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database (MySQL in production) ───────────────────────────────────────────
DB_ENGINE=django.db.backends.mysql
DB_NAME=railway_control
DB_USER=railway_user
DB_PASSWORD=your_db_password_here
DB_HOST=127.0.0.1
DB_PORT=3306

# ── For local dev with SQLite (comment out MySQL block above) ─────────────────
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db_dev.sqlite3

# ── File paths ────────────────────────────────────────────────────────────────
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media
ML_MODEL_PATH=/app/ml_models/delay_model.pkl

# ── Email (dev = console backend, prod = smtp) ────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=RailControl AI <noreply@railcontrol.ai>
